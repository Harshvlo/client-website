VITE_CONTACT_FORM_ENDPOINT=/api/contact

# SMTP email settings for the backend server
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
CONTACT_TO_EMAIL=info@vexarocouriersolutions.com
CONTACT_FROM_EMAIL=no-reply@vexaro.com
CONTACT_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_RATE_LIMIT_MAX=5
